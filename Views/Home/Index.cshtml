@model List<Microsoft.AspNetCore.Identity.IdentityUser>
@{
    ViewData["Title"] = "Գլխավոր էջ";
}



<div class="container mt-5">
    <div class="row">
        <div class="col-md-12 mb-4">
            <div class="date-picker-row">
                <div class="date-picker-container">
                    <h3 class="text-center mb-3">Ընտրեք ամսաթիվը</h3>
                    <div class="date-picker-wrapper">
                        <button id="prevDay" class="btn btn-secondary">&lt;</button>
                        <input type="text" id="reportDate" class="form-control" readonly>
                        <button id="nextDay" class="btn btn-secondary">&gt;</button>
                    </div>
                    <input type="hidden" id="reportDateHidden" value="@DateTime.Now.ToString("dd-MM-yyyy")">
                </div>
            </div>
        </div>
        @if (User.IsInRole("Admin") && Model != null && Model.Any())
        {
            foreach (var user in Model)
            {
                <div class="col-md-3 mb-4">
                    <a href="#" class="service-window-link" data-userid="@user.Id">
                        <div class="service-window animated-window" id="service-@user.Id">
                            <h3 class="user-name">@user.UserName</h3>
                            <div class="sub-windows">
                                <div class="sub-window calendar">
                                    <h3>Գրանցումներ</h3>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
    </div>
</div>

@section Scripts
{
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.min.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
    <script>
        $(document).ready(function () {
            // Set current date on page load
            var today = new Date();
            $("#reportDate").datepicker("setDate", today);
            var formattedDate = $.datepicker.formatDate('yy-mm-dd', today);
            $("#reportDateHidden").val(formattedDate);
            updateLinks(formattedDate);


            let isCalendarOpen = false;

            $("#reportDate").datepicker({
                dateFormat: 'dd/mm/yy',
                changeMonth: true,
                changeYear: true,
                yearRange: "-0:+1",
                onSelect: function (dateText, inst) {
                    var date = $(this).datepicker('getDate');
                    var formattedDate = $.datepicker.formatDate('yy-mm-dd', date);
                    $("#reportDateHidden").val(formattedDate);
                    updateLinks(formattedDate);
                    isCalendarOpen = false;
                }
            });

            function changeDate(days) {
                var currentDate = $("#reportDate").datepicker('getDate');
                currentDate.setDate(currentDate.getDate() + days);
                $("#reportDate").datepicker("setDate", currentDate);
                var formattedDate = $.datepicker.formatDate('yy-mm-dd', currentDate);
                $("#reportDateHidden").val(formattedDate);
                updateLinks(formattedDate);
            }

            $('.date-picker-container').on('click', function () {
                if (isCalendarOpen) {
                    $("#reportDate").datepicker("hide");
                    isCalendarOpen = false;
                } else {
                    $("#reportDate").datepicker("show");
                    isCalendarOpen = true;
                }
            });

            $(document).on('click', function (e) {
                if (!$(e.target).closest('.date-picker-container, .ui-datepicker').length) {
                    $("#reportDate").datepicker("hide");
                    isCalendarOpen = false;
                }
            });

            // Set initial date
            var initialDate = $("#reportDateHidden").val();
            if (initialDate) {
                $("#reportDate").datepicker("setDate", new Date(initialDate));
                updateLinks(initialDate);
            }

            $("#prevDay").on("click", function (e) {
                e.stopPropagation(); // Կանխում ենք իրադարձության տարածումը
                var selectedDate = $("#reportDate").datepicker('getDate');
                selectedDate.setDate(selectedDate.getDate() - 1);
                $("#reportDate").datepicker("setDate", selectedDate);
                updateLinks($.datepicker.formatDate('yy-mm-dd', selectedDate));
            });

            $("#nextDay").on("click", function (e) {
                e.stopPropagation(); // Կանխում ենք իրադարձության տարածումը
                var selectedDate = $("#reportDate").datepicker('getDate');
                selectedDate.setDate(selectedDate.getDate() + 1);
                $("#reportDate").datepicker("setDate", selectedDate);
                updateLinks($.datepicker.formatDate('yy-mm-dd', selectedDate));
            });

            function updateLinks(date) {
                $('.service-window-link').each(function () {
                    var userId = $(this).data('userid');
                    var newHref = '@Url.Action("Index", "Appointments")' + '?userId=' + userId + '&selectedDate=' + date;
                    $(this).attr('href', newHref);
                });
            }

            setTimeout(animateWindows, 500);

            function animateWindows() {
                $('.animated-window').each(function (index) {
                    var $window = $(this);
                    setTimeout(function () {
                        $window.removeClass('hidden-window').css('display', 'block');
                        setTimeout(function () {
                            $window.addClass('show');
                        }, 50);
                    }, index * 150);
                });
            }

            $('.navbar-brand').click(function (e) {
                e.preventDefault();
                $('.animated-window').addClass('hidden-window').removeClass('show');
                setTimeout(animateWindows, 500);
            });
        });
    </script>





    <style>
        .container {
            margin-top: 2rem;
        }

        .date-picker-row {
            display: flex;
            justify-content: flex-start;
            width: 100%;
            margin-bottom: 2rem;
        }

        .date-picker-container {
            background-color: #f8f9fa;
            padding: 1.5rem;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            width: 350px;
        }

        .date-picker-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        #reportDate {
            width: 140px;
            text-align: center;
            font-size: 1.1rem;
            margin: 0 0.5rem;
            border: 1px solid #ced4da;
            border-radius: 5px;
            padding: 0.5rem;
        }

        #prevDay, #nextDay {
            font-size: 1.1rem;
            padding: 0.5rem 1rem;
            background-color: #6c757d;
            border-color: #6c757d;
            color: white;
            border-radius: 5px;
            transition: background-color 0.3s ease;
        }

            #prevDay:hover, #nextDay:hover {
                background-color: #5a6268;
                border-color: #545b62;
            }

        .service-window-link {
            text-decoration: none;
            color: inherit;
            display: block;
            transition: transform 0.3s ease;
        }

            .service-window-link:hover {
                transform: translateY(-5px);
            }

        .service-window {
            background: linear-gradient(135deg, #f6f6f6 0%, #e9e9e9 100%);
            padding: 1.5rem;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 1.5rem;
            width: 100%;
            height: 280px;
            overflow: hidden;
            position: relative;
            border: none;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        }

            .service-window:hover {
                box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
                transform: translateY(-5px);
            }

            .service-window::before {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0) 70%);
                transform: rotate(30deg);
            }

        .user-name {
            font-size: 1.6rem;
            font-weight: 600;
            color: #333;
            margin-bottom: 1rem;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 1px;
            position: relative;
            z-index: 1;
        }

        .sub-windows {
            position: absolute;
            bottom: 1rem;
            left: 1rem;
            right: 1rem;
            transition: all 0.3s ease;
            border: none;
        }

        .sub-window.calendar {
            background: linear-gradient(135deg, #4a4a4a 0%, #2d2d2d 100%);
            padding: 1.2rem;
            border: none;
            margin-top: 0.5rem;
            border-radius: 15px;
            transition: all 0.3s ease;
            text-align: center;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }

        .sub-window:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
        }

        .sub-window h3 {
            margin: 0;
            font-size: 1.2rem;
            color: #ffffff;
            font-weight: 500;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
        }

        .animated-window {
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.5s ease, transform 0.5s ease;
        }

            .animated-window.show {
                opacity: 1;
                transform: translateY(0);
            }

        /* Թարմացված jQuery UI DatePicker ոճեր */
        .ui-datepicker {
            font-size: 1rem;
            padding: 0.5rem;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .ui-datepicker-header {
            background-color: #f8f9fa;
            border: none;
            border-radius: 10px 10px 0 0;
        }

        .ui-datepicker-calendar {
            background-color: white;
        }

        .ui-datepicker-title {
            color: #333;
        }

        .ui-datepicker-prev, .ui-datepicker-next {
            background: none;
            border: none;
            color: #6c757d;
        }

            .ui-datepicker-prev:hover, .ui-datepicker-next:hover {
                background-color: #e9ecef;
                color: #495057;
            }
    </style>
}