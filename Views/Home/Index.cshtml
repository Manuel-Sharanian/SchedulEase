@model List<UserDashboardViewModel>
@using System.Linq;
@{
    ViewData["Title"] = "Գլխավոր էջ";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12 mb-4">
            <div class="date-picker-row">
                <div class="date-picker-container">
                    <h3 class="text-center mb-3 date-picker-title">Ընտրեք ամսաթիվը</h3>
                    <div class="date-picker-wrapper">
                        <div id="inline-calendar"></div>
                    </div>
                    <input type="hidden" id="reportDateHidden" value="@ViewBag.SelectedDate.ToString("yyyy-MM-dd")">
                </div>
            </div>
        </div>
        @if ((User.IsInRole("Admin") || User.IsInRole("Manager")) && Model != null && Model.Any())
        {
            <div class="col-md-12">
                <div class="swiper-container">
                    <div class="swiper-wrapper">
                        @foreach (var user in Model)
                        {
                            <div class="swiper-slide">
                                <a href="#" class="service-window-link" data-userid="@user.UserId">
                                    <div class="service-window animated-window @(user.HasIncomeReport ? "has-income-report" : "")" id="service-@user.UserId">
                                        <h3 class="user-name">@(string.Concat(user.UserName.Select((c, i) => i == 0 || (i > 0 && user.UserName[i - 1] == ' ') ? char.ToUpper(c) : char.ToLower(c))))</h3>
                                        <div class="sub-windows">
                                            <div class="sub-window calendar">
                                                <h3>Գրանցումներ</h3>
                                            </div>
                                            <div class="sub-window appointments-count">
                                                <h3>Կատարված գրանցումներ: @user.CompletedAppointmentsCount</h3>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                    <div class="swiper-pagination"></div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts
{
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://npmcdn.com/flatpickr/dist/l10n/hy.js"></script>
    <script src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css">
    <script>
        $(document).ready(function () {
            var today = new Date();
            var formattedToday = formatDate(today);
            var selectedDate = $('#reportDateHidden').val();

            var calendar = flatpickr("#inline-calendar", {
                inline: true,
                defaultDate: selectedDate,
                dateFormat: "Y-m-d",
                locale: "hy",
                onChange: function (selectedDates, dateStr, instance) {
                    updateLinks(dateStr);
                    window.location.href = '@Url.Action("Index", "Home")' + '?selectedDate=' + dateStr;
                }
            });

            calendar.open();

            updateLinks(formattedToday);

            // Սկզբնական լինքերի թարմացում
            updateLinks(selectedDate);

            function updateLinks(date) {
                $('.service-window-link').each(function () {
                    var userId = $(this).data('userid');
                    var newHref = '@Url.Action("Index", "Appointments")' + '?userId=' + userId + '&selectedDate=' + date;
                    $(this).attr('href', newHref);
                });
            }

            function formatDate(date) {
                var d = new Date(date),
                    month = '' + (d.getMonth() + 1),
                    day = '' + d.getDate(),
                    year = d.getFullYear();

                if (month.length < 2)
                    month = '0' + month;
                if (day.length < 2)
                    day = '0' + day;

                return [year, month, day].join('-');
            }

            setTimeout(animateWindows, 500);

            function animateWindows() {
                $('.animated-window').each(function (index) {
                    var $window = $(this);
                    setTimeout(function () {
                        $window.removeClass('hidden-window').css('display', 'block');
                        setTimeout(function () {
                            $window.addClass('show');
                        }, 50);
                    }, index * 150);
                });
            }

            $('.navbar-brand').click(function (e) {
                e.preventDefault();
                $('.animated-window').addClass('hidden-window').removeClass('show');
                setTimeout(animateWindows, 500);
            });

            var swiper = new Swiper('.swiper-container', {
                slidesPerView: 'auto',
                spaceBetween: 30,
                loop: true,
                loopedSlides: 2,
                pagination: {
                    el: '.swiper-pagination',
                    clickable: true,
                },
                breakpoints: {
                    768: {
                        slidesPerView: 4,
                        spaceBetween: 30,
                    },
                }
            });
        });
    </script>


    <style>
        /* Dark Gray Flatpickr Design */
        .flatpickr-calendar {
            background-color: #2d2d2d;
            color: white;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
            border-radius: 15px;
            padding: 20px;
            width: 100%;
            max-width: 350px;
            margin: 0 auto;
        }

        .flatpickr-day {
            background-color: #2d2d2d;
            color: white;
            border-radius: 50%;
        }

            .flatpickr-day:hover {
                background-color: #3a3a3a;
            }

            .flatpickr-day.selected {
                background-color: #4a4a4a;
                border-color: #4a4a4a;
            }

        /* Ամիսների վերնամասի ոճեր */
        .flatpickr-months, .flatpickr-weekdays {
            background: #333 !important;
        }

        .flatpickr-month, .flatpickr-weekday {
            color: #fff !important;
            fill: #fff !important;
        }

        /* Ամիսների ցանկի ոճեր */
        .flatpickr-monthDropdown-months {
            background: #333 !important;
            color: #fff !important;
            height: 24px !important;
        }

        /* Ամիսների ցանկի տարբերակների ոճեր */
        .flatpickr-monthDropdown-month {
            background-color: #404040 !important;
            color: #fff !important;
        }

            /* Ամիսների ցանկի hover էֆեկտ */
            .flatpickr-monthDropdown-month:hover {
                background-color: #505050 !important;
            }

            /* Ընտրված ամսվա ոճ */
            .flatpickr-monthDropdown-month.selected {
                background-color: #666 !important;
            }


        .numInputWrapper span.arrowUp,
        .numInputWrapper span.arrowDown {
            border-color: white transparent;
        }

        .date-picker-title {
            color: #a9a9a9; /* Բաց մոխրագույն */
            transition: color 0.3s ease;
        }

            .date-picker-title:hover {
                color: #4a4a4a; /* Մուգ մոխրագույն */
            }

        .service-window-link {
            text-decoration: none;
            color: inherit;
            display: block;
            transition: transform 0.3s ease;
        }

            .service-window-link:hover {
                transform: translateY(-5px);
            }

        .service-window {
            background: linear-gradient(135deg, #4a4a4a 0%, #333333 100%);
            padding: 1.5rem;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 1.5rem;
            width: 100%;
            height: 280px;
            overflow: hidden;
            position: relative;
            border: none;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        }

            .service-window:hover {
                box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
                transform: translateY(-5px);
            }

            .service-window::before {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 70%);
                transform: rotate(30deg);
            }

        .user-name {
            font-size: 1.6rem;
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 1rem;
            text-align: center;
            letter-spacing: 1px;
            position: relative;
            z-index: 1;
        }

        .sub-windows {
            position: absolute;
            bottom: 1rem;
            left: 1rem;
            right: 1rem;
            transition: all 0.3s ease;
            border: none;
        }

        .sub-window.calendar {
            background: linear-gradient(135deg, #4a4a4a 0%, #2d2d2d 100%);
            padding: 1.2rem;
            border: none;
            margin-top: 0.5rem;
            border-radius: 15px;
            transition: all 0.3s ease;
            text-align: center;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }

        .sub-window:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
        }

        .sub-window h3 {
            margin: 0;
            font-size: 1.2rem;
            color: #ffffff;
            font-weight: 500;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
        }

        .animated-window {
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.5s ease, transform 0.5s ease;
        }

            .animated-window.show {
                opacity: 1;
                transform: translateY(0);
            }

        .service-window.has-income-report {
            background: linear-gradient(135deg, #56ab2f 0%, #45a049 100%);
        }

        .service-window.has-income-report .user-name,
        .service-window.has-income-report .sub-window h3 {
            color: #ffffff;
        }

        .sub-window.appointments-count {
            background: linear-gradient(135deg, #4a4a4a 0%, #2d2d2d 100%);
            padding: 1.2rem;
            border: none;
            margin-top: 0.5rem;
            border-radius: 15px;
            transition: all 0.3s ease;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }

        .sub-window.appointments-count h3 {
            margin: 0;
            font-size: 1.1rem;
            color: #ffffff;
            font-weight: 500;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
        }

        @@media (max-width: 767px) {
            .swiper-container {
                overflow: hidden;
                padding: 20px 0;
            }

            .swiper-slide {
                width: 80%;
            }

            .service-window {
                margin-bottom: 0;
            }

            .swiper-container {
                padding: 20px 0;
                overflow: hidden;
            }

            .swiper-slide {
                height: auto;
                width: 280px;
            }

            .swiper-pagination {
                position: static;
                margin-top: 20px;
            }
        }
    </style>
}