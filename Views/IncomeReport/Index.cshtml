@model IncomeReportViewModel
@if (Model.IsAdmin || Model.IsManager)
{
    <div class="user-buttons-container mb-3">
        @foreach (var userReport in Model.UserReports)
        {
            <button class="btn btn-outline-primary btn-sm user-report-btn mb-2"
                    data-user-id="@userReport.Id"
                    data-user-name="@userReport.UserName">
                @userReport.UserName
            </button>
        }
    </div>
}
<div class="container">
    <h2 class="text-center page-title">Ընդհանուր Եկամտի հաշվետվություն</h2>

    <div class="d-flex justify-content-between align-items-center">
        <div class="date-picker-container">
            <input type="text" id="dateRange" class="form-control" style="max-width: 300px;" readonly>
        </div>
    </div>
    <div class="summary-container">
        <h4 class="text-center mb-3">Ժամանակահատված: <span id="displayDateRange"></span></h4>
        <div class="amount-box employer mb-3">
            <p class="mb-1">Գործատուի մաս (Ընդհանուր)</p>
            <h4 id="totalEmployerAmount">@Model.EmployerAmount.ToString("N2") ֏</h4>
        </div>
        <div class="amount-box employee mb-3">
            <p class="mb-1">Աշխատողի մաս (Ընդհանուր)</p>
            <h4 id="totalEmployeeAmount">@Model.EmployeeAmount.ToString("N2") ֏</h4>
        </div>
        <div class="amount-box total mb-3">
            <p class="mb-1">Ընդհանուր գումար</p>
            <h4 id="totalAmount">@Model.TotalAmount.ToString("N2") ֏</h4>
        </div>
        <div class="amount-box appointments">
            <p class="mb-1">Ընդհանուր կատարված նշանակումների քանակ</p>
            <h4 id="totalCompletedAppointments">@Model.CompletedAppointments</h4>
        </div>
    </div>
</div>

<!-- Մոդալ պատուհան օգտատիրոջ հաշվետվության համար -->
<div class="modal fade" id="userReportModal" tabindex="-1" role="dialog" aria-labelledby="userReportModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="userReportModalLabel">Օգտատիրոջ հաշվետվություն</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="userReportModalBody">
                <!-- Այստեղ կլինի օգտատիրոջ հաշվետվության բովանդակությունը -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        $(document).ready(function () {
            var today = new Date();

            // Հայերեն լոկալիզացիա flatpickr-ի համար
            const Armenian = {
                weekdays: {
                    shorthand: ["Կիր", "Երկ", "Երք", "Չրք", "Հնգ", "Ուրբ", "Շբթ"],
                    longhand: [
                        "Կիրակի",
                        "Երկուշաբթի",
                        "Երեքշաբթի",
                        "Չորեքշաբթի",
                        "Հինգշաբթի",
                        "Ուրբաթ",
                        "Շաբաթ",
                    ],
                },
                months: {
                    shorthand: [
                        "Հնվ",
                        "Փտր",
                        "Մրտ",
                        "Ապր",
                        "Մյս",
                        "Հնս",
                        "Հլս",
                        "Օգս",
                        "Սպտ",
                        "Հկտ",
                        "Նմբ",
                        "Դկտ",
                    ],
                    longhand: [
                        "Հունվար",
                        "Փետրվար",
                        "Մարտ",
                        "Ապրիլ",
                        "Մայիս",
                        "Հունիս",
                        "Հուլիս",
                        "Օգոստոս",
                        "Սեպտեմբեր",
                        "Հոկտեմբեր",
                        "Նոյեմբեր",
                        "Դեկտեմբեր",
                    ],
                },
                firstDayOfWeek: 1,
                ordinal: function () {
                    return "";
                }
            };

            flatpickr.localize(Armenian); // Սահմանել հայերեն լոկալիզացիան

            var fp = flatpickr("#dateRange", {
                mode: "range",
                dateFormat: "d/m/Y",
                defaultDate: [today, today],
                minDate: "2024-01-01",
                onClose: function (selectedDates, dateStr, instance) {
                    if (selectedDates.length === 0) {
                        instance.setDate([instance.latestSelectedDateObj, instance.latestSelectedDateObj]);
                    } else if (selectedDates.length === 1) {
                        instance.setDate([selectedDates[0], selectedDates[0]]);
                    }
                },
                onChange: function (selectedDates, dateStr, instance) {
                    if (selectedDates.length === 1) {
                        updateReportData(selectedDates[0], selectedDates[0]);
                    } else if (selectedDates.length === 2) {
                        updateReportData(selectedDates[0], selectedDates[1]);
                    }
                }
            });

            $('.close').click(function () {
                $('#userReportModal').modal('hide');
            });

            function updateReportData(startDate, endDate) {
                var adjustedStartDate = new Date(startDate.getTime() - startDate.getTimezoneOffset() * 60000);
                var adjustedEndDate = new Date(endDate.getTime() - endDate.getTimezoneOffset() * 60000);

                $.ajax({
                    url: '/IncomeReport/GetReportData',
                    type: 'GET',
                    data: {
                        startDate: adjustedStartDate.toISOString(),
                        endDate: adjustedEndDate.toISOString()
                    },
                    success: function (data) {
                        $('#totalEmployeeAmount').text((data.employeeAmount || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ֏');
                        $('#totalEmployerAmount').text((data.employerAmount || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ֏');
                        $('#totalAmount').text((data.totalAmount || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ֏');
                        $('#totalCompletedAppointments').text(data.completedAppointments || 0);
                        $('#displayDateRange').text(formatDateRange(startDate, endDate));
                    },
                    error: function (xhr, status, error) {
                        alert('Սխալ տվյալները ստանալիս');
                    }
                });
            }

            function formatDateRange(start, end) {
                if (start.getTime() === end.getTime()) {
                    return start.toLocaleDateString('en-GB');
                }
                return start.toLocaleDateString('en-GB') + ' - ' + end.toLocaleDateString('en-GB');
            }

            // Օգտատիրոջ հաշվետվության կոճակի սեղմման իրադարձություն
            $('.user-report-btn').click(function () {
                var userId = $(this).data('user-id');
                var userName = $(this).data('user-name');
                var startDate = fp.selectedDates[0];
                var endDate = fp.selectedDates[1] || startDate;

                // Ապահովում ենք, որ մեկ օրվա ընտրության դեպքում ժամանակահատվածը ներառի ամբողջ օրը
                var adjustedStartDate = new Date(startDate);
                adjustedStartDate.setHours(0, 0, 0, 0);
        
                var adjustedEndDate = new Date(endDate);
                adjustedEndDate.setHours(23, 59, 59, 999);

                $.ajax({
                    url: '/IncomeReport/GetUserReportData',
                    type: 'GET',
                    data: {
                        userId: userId,
                        startDate: adjustedStartDate.toISOString(),
                        endDate: adjustedEndDate.toISOString()
                    },
                    success: function (data) {
                        var modalContent = `
                            <h4>${userName}</h4>
                            <p>Ժամանակահատված: ${formatDateRange(adjustedStartDate, adjustedEndDate)}</p>
                            <p>Աշխատողի մաս: ${data.employeeAmount.toLocaleString('hy-AM', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ֏</p>
                            <p>Գործատուի մաս: ${data.employerAmount.toLocaleString('hy-AM', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ֏</p>
                            <p>Ընդհանուր գումար: ${data.totalAmount.toLocaleString('hy-AM', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ֏</p>
                            <p>Կատարված նշանակումներ: ${data.completedAppointments}</p>
                        `;
                        $('#userReportModalBody').html(modalContent);
                        $('#userReportModal').modal('show');
                    },
                    error: function () {
                        alert('Սխալ օգտատիրոջ տվյալները ստանալիս');
                    }
                });
            });

            function formatDateRange(start, end) {
                var options = { day: '2-digit', month: '2-digit', year: 'numeric' };
                if (start.getTime() === end.getTime()) {
                    return start.toLocaleDateString('hy-AM', options);
                }
                return `${start.toLocaleDateString('hy-AM', options)} - ${end.toLocaleDateString('hy-AM', options)}`;
            }

            // Սկզբնական թարմացում այսօրվա ամսաթվով
            updateReportData(today, today);
        });
    </script>
}


<style>
    body {
        background-color: #f0f0f0;
        color: #333;
        font-family: Arial, sans-serif;
    }

    .container {
        background-color: #fff;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        padding: 20px;
        max-width: 600px;
        margin: 20px auto;
    }

    .page-title {
        color: #4a4a4a;
        margin-bottom: 20px;
    }

    .btn-outline-secondary {
        color: #fff;
        border-color: #4a4a4a;
        background-color: #4a4a4a;
    }

        .btn-outline-secondary:hover {
            background-color: #333;
            color: #fff;
        }

    .summary-container {
        background-color: #e6e6e6;
        border-radius: 8px;
        padding: 15px;
        margin-top: 20px;
    }

    .amount-box {
        background-color: #d9d9d9;
        border-radius: 8px;
        padding: 10px;
        margin-bottom: 10px;
    }

    .amount-title {
        font-size: 14px;
        margin-bottom: 5px;
    }

    .amount-value {
        font-size: 18px;
        font-weight: bold;
    }

    .date-picker-container {
        position: relative;
        cursor: pointer;
        margin: 20px auto;
    }

        .date-picker-container input[type="text"] {
            background-color: #fff;
            cursor: pointer;
            text-align: center;
        }

    .amount-box.total {
        background-color: #c9e6ff;
    }

    .user-buttons-container {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: center;
    }

    .modal-content {
        background-color: #f8f9fa;
        border-radius: 10px;
    }

    .modal-header {
        background-color: #e9ecef;
        border-bottom: 1px solid #dee2e6;
        border-top-left-radius: 10px;
        border-top-right-radius: 10px;
    }

    .modal-body {
        padding: 20px;
    }

    .user-report-btn {
        font-size: 0.9em;
        padding: 5px 10px;
        background-color: #e9ecef;
        color: #495057;
        border-color: #ced4da;
    }

        .user-report-btn:hover {
            background-color: #dee2e6;
            color: #212529;
        }
</style>