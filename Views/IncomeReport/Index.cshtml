@model IncomeReportViewModel

<div class="container">
    <h2 class="text-center page-title">Ընդհանուր Եկամտի հաշվետվություն</h2>
    <div class="d-flex justify-content-between align-items-center">
        <div class="date-picker-container">
            <input type="text" id="dateRange" class="form-control" style="max-width: 300px;" readonly>
        </div>
    </div>
    <div class="summary-container">
        <h4 class="text-center mb-3">Ժամանակահատված: <span id="displayDateRange"></span></h4>
        <div class="amount-box employer mb-3">
            <p class="mb-1">Գործատուի մաս (Ընդհանուր)</p>
            <h4 id="totalEmployerAmount">@Model.EmployerAmount.ToString("N2") ֏</h4>
        </div>
        <div class="amount-box employee mb-3">
            <p class="mb-1">Աշխատողի մաս (Ընդհանուր)</p>
            <h4 id="totalEmployeeAmount">@Model.EmployeeAmount.ToString("N2") ֏</h4>
        </div>
        <div class="amount-box total mb-3">
            <p class="mb-1">Ընդհանուր գումար</p>
            <h4 id="totalAmount">@Model.TotalAmount.ToString("N2") ֏</h4>
        </div>
        <div class="amount-box appointments">
            <p class="mb-1">Ընդհանուր կատարված նշանակումների քանակ</p>
            <h4 id="totalCompletedAppointments">@Model.CompletedAppointments</h4>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        $(document).ready(function () {
            var today = new Date();
            var fp = flatpickr("#dateRange", {
                mode: "range",
                dateFormat: "d/m/Y",
                defaultDate: [today, today],
                minDate: "2024-01-01",
                onChange: function (selectedDates, dateStr, instance) {
                    if (selectedDates.length === 1) {
                        // Single day selection
                        updateReportData(selectedDates[0], selectedDates[0]);
                    } else if (selectedDates.length === 2) {
                        // Date range selection
                        updateReportData(selectedDates[0], selectedDates[1]);
                    }
                }
            });

            function updateReportData(startDate, endDate) {
                // Adjust dates to local timezone
                var adjustedStartDate = new Date(startDate.getTime() - startDate.getTimezoneOffset() * 60000);
                var adjustedEndDate = new Date(endDate.getTime() - endDate.getTimezoneOffset() * 60000);

                $.ajax({
                    url: '/IncomeReport/GetReportData',
                    type: 'GET',
                    data: {
                        startDate: adjustedStartDate.toISOString(),
                        endDate: adjustedEndDate.toISOString()
                    },
                    success: function (data) {
                        $('#totalEmployeeAmount').text((data.employeeAmount || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ֏');
                        $('#totalEmployerAmount').text((data.employerAmount || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ֏');
                        $('#totalAmount').text((data.totalAmount || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ֏');
                        $('#totalCompletedAppointments').text(data.completedAppointments || 0);
                        $('#displayDateRange').text(formatDateRange(startDate, endDate));
                    },
                    error: function (xhr, status, error) {
                        alert('Սխալ տվյալները ստանալիս');
                    }
                });
            }

            function formatDateRange(start, end) {
                if (start.getTime() === end.getTime()) {
                    return start.toLocaleDateString('en-GB');
                }
                return start.toLocaleDateString('en-GB') + ' - ' + end.toLocaleDateString('en-GB');
            }

            // Initial update with today's date
            updateReportData(today, today);
        });
    </script>
}


<style>
    body {
        background-color: #f0f0f0;
        color: #333;
        font-family: Arial, sans-serif;
    }

    .container {
        background-color: #fff;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        padding: 20px;
        max-width: 600px;
        margin: 20px auto;
    }

    .page-title {
        color: #4a4a4a;
        margin-bottom: 20px;
    }

    .btn-outline-secondary {
        color: #fff;
        border-color: #4a4a4a;
        background-color: #4a4a4a;
    }

        .btn-outline-secondary:hover {
            background-color: #333;
            color: #fff;
        }

    .summary-container {
        background-color: #e6e6e6;
        border-radius: 8px;
        padding: 15px;
        margin-top: 20px;
    }

    .amount-box {
        background-color: #d9d9d9;
        border-radius: 8px;
        padding: 10px;
        margin-bottom: 10px;
    }

    .amount-title {
        font-size: 14px;
        margin-bottom: 5px;
    }

    .amount-value {
        font-size: 18px;
        font-weight: bold;
    }

    .date-picker-container {
        position: relative;
        cursor: pointer;
        margin: 20px auto;
    }

        .date-picker-container input[type="text"] {
            background-color: #fff;
            cursor: pointer;
            text-align: center;
        }

    .amount-box.total {
        background-color: #c9e6ff;
    }
</style>