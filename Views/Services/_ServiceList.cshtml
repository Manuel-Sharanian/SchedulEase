@model IEnumerable<BeautySalon.Models.Service>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@foreach (var item in Model)
{
    <div class="service-card">
        <h3 class="service-name">@item.ServiceName</h3>
        <p class="service-price">@item.Price դրամ</p>
        @if (User.IsInRole("Admin"))
        {
            <div class="admin-actions">
                <a class="btn btn-info" asp-action="Edit" asp-route-id="@item.Id">
                    <i class="fas fa-edit"></i> <span class="action-text">Փոփոխել</span>
                </a>
                <a class="btn btn-danger" asp-action="Delete" asp-route-id="@item.Id">
                    <i class="fas fa-trash-alt"></i> <span class="action-text">Ջնջել</span>
                </a>
            </div>
        }
    </div>
}

<style>
    .service-card {
        background-color: #3c3c3c;
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        padding: 20px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        width: calc(33.333% - 20px);
        margin-bottom: 20px;
    }
    .service-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 6px 12px rgba(0,0,0,0.4);
    }
    .service-name {
        font-size: 1.2rem;
        color: #ffffff;
        margin-bottom: 10px;
    }
    .service-price {
        font-size: 1.5rem;
        color: #4CAF50;
        font-weight: bold;
    }
    .admin-actions {
        margin-top: 15px;
        display: flex;
        justify-content: space-between;
    }
    .btn {
        padding: 8px 12px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        transition: background-color 0.3s ease;
    }
    .btn-info {
        background-color: #2196F3;
        color: white;
    }
    .btn-info:hover {
        background-color: #0b7dda;
    }
    .btn-danger {
        background-color: #f44336;
        color: white;
    }
    .btn-danger:hover {
        background-color: #da190b;
    }
    @@media (max-width: 768px) {
        .service-card {
            flex: 0 0 80%;
            width: 80%;
            height: auto;
            min-height: 200px;
            scroll-snap-align: start;
        }
        .admin-actions {
            flex-direction: row;
            justify-content: space-between;
        }
        .btn {
            width: 48%;
        }
        .action-text {
            display: none;
        }
    }
</style>