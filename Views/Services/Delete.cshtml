@model BeautySalon.Models.Service
@{
    ViewData["Title"] = "Delete";
}
<div class="container">
    <h3 class="page-title">Ջնջել հետևյալ ծառայությունը?</h3>
    <hr />
    <div class="row justify-content-center">
        <div class="col-md-6">
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="form-group">
                    <label asp-for="ServiceName" class="control-label"></label>
                    <input asp-for="ServiceName" class="form-control" readonly />
                </div>
                <div class="form-group">
                    <label asp-for="Price" class="control-label"></label>
                    <input asp-for="Price" class="form-control" readonly />
                </div>
                <div class="form-group text-center">
                    <input type="submit" value="Ջնջել" class="btn btn-danger btn-lg" />
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #e0e0e0;
    }

    .container {
        margin-top: 50px;
    }

    .page-title {
        color: #4e4e4e;
        font-family: 'Arial', sans-serif;
        font-weight: bold;
        text-align: center;
    }

    .form-control {
        padding: 15px;
        margin-bottom: 15px;
        box-shadow: 0 0 5px rgba(0, 0, 0, 0.1);
        transition: box-shadow 0.3s ease, border-color 0.3s ease;
        background-color: #f9f9f9;
        color: #333333;
        border: 1px solid #ccc;
    }

        .form-control:focus {
            box-shadow: 0 0 10px rgba(128, 128, 128, 0.5);
            border-color: #808080;
            background-color: #f1f1f1;
            color: #333333;
        }

    .btn-danger {
        background-color: #dc3545;
        border-color: #dc3545;
        padding: 10px 30px;
    }

        .btn-danger:hover {
            background-color: #c82333;
            border-color: #bd2130;
        }
</style>