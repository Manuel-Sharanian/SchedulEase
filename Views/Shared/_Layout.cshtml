<!DOCTYPE html>
<html lang="hy">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/meta3.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SchedulEase.styles.css" asp-append-version="true" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.0/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/ui/1.13.0/jquery-ui.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <header>
        <nav class="navbar fixed-top-custom">
            <div class="container-fluid px-3">
                <div class="w-100 d-flex justify-content-between align-items-center">
                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                        SchedulEase
                        <svg class="arrow-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2L12 22M12 2L16 6M12 2L8 6M12 2L20 10M12 2L4 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </a>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <button class="navbar-toggler" type="button" aria-label="Toggle navigation">
                            <span class="icon-bar"></span>
                            <span class="icon-bar"></span>
                            <span class="icon-bar"></span>
                        </button>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="sidebar">
        <div class="sidebar-header">
            <button class="close-sidebar d-md-none">&larr;</button>
            <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                SchedulEase
                <svg class="arrow-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2L12 22M12 2L16 6M12 2L8 6M12 2L20 10M12 2L4 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </a>
        </div>
        <div class="sidebar-content">
            @if (User.Identity.IsAuthenticated)
            {
                <div class="user-greeting">
                    <i class="fas fa-hand-wave"></i> Բարև @User.Identity?.Name!
                </div>
            }
            <ul class="nav flex-column main-nav">
                 @*             @if (User.IsInRole("Admin"))
                {
                <li class="nav-item">
                <a class="nav-link" asp-controller="Clients" asp-action="index">Հաճախորդներ</a>
                </li>
                } *@
                @if (!User.IsInRole("Manager"))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Appointments" asp-action="index">
                            <i class="fas fa-calendar-check"></i> <span>Իմ Գրանցումները</span>
                        </a>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Services" asp-action="index">
                        <i class="fas fa-cut"></i> <span>Ծառայություններ</span>
                    </a>
                </li>
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="index">
                            <i class="fas fa-users"></i> <span>Օգտատերեր</span>
                        </a>
                    </li>
                }
                @if (User.IsInRole("Manager"))
                {
                    <li class="nav-item">
                        <a asp-controller="IncomeReport" asp-action="Index" class="nav-link">
                            <i class="fas fa-chart-line"></i> <span>Եկամտի հաշվետվություն</span>
                        </a>
                    </li>
                }
            </ul>
            <partial name="_LoginPartial" />
        </div>
    </div>
    </div>

    <div class="content-wrapper">
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <div class="overlay"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function () {
            var $navbarToggler = $('.navbar-toggler');
            if ($navbarToggler.length > 0) {  // Ստուգում ենք, արդյոք Hamburger Icon-ը գոյություն ունի
                var $sidebar = $('.sidebar');
                var $overlay = $('.overlay');
                var $body = $('body');
                var $closeSidebar = $('.close-sidebar');

                function toggleMenu() {
                    $navbarToggler.toggleClass('is-active');
                    $sidebar.toggleClass('active');
                    $overlay.toggleClass('active');
                    $body.toggleClass('sidebar-active');
                }

                $navbarToggler.on('click', function (e) {
                    e.preventDefault();
                    toggleMenu();
                });

                $overlay.on('click', function () {
                    toggleMenu();
                });

                $closeSidebar.on('click', function () {
                    toggleMenu();
                });
            }
                    if (@User.Identity.IsAuthenticated.ToString().ToLower()) {
                $('body').addClass('user-authenticated');
                }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>