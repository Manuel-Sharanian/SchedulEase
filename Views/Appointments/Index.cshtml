                        },
                        error: function (xhr, status, error) {
                            console.error('Error:', error);
                            alert('Սխալ եկամտի հաշվետվությունը պահպանելիս: ' + error);
                        }
                    });
                }
            }).catch(function (error) {
                console.error('Error in checkZeroValueAppointments:', error);
                alert('Սխալ տեղի ունեցավ նշանակումները ստուգելիս: ' + error);
