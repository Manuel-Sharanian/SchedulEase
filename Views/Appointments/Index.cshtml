@model IEnumerable<BeautySalon.Models.AppointmentViewModel>
@{
    ViewData["Title"] = ViewBag.UserName;
    DateTime selectedDate = ViewBag.SelectedDate ?? DateTime.Today;
    bool isAdmin = ViewBag.IsAdmin ?? false;
    int appointmentCounter = 0;
}
<h1 class="text-center mb-4 page-title">Գրանցումներ - @ViewBag.UserName</h1>

<div class="container mt-4">
    <!-- Դեսքթոփ տարբերակ -->
    <div class="row mb-4">
        <div class="col-md-6 d-flex align-items-center">
            <div class="date-input-wrapper flex-grow-1">
                <div class="d-flex align-items-center">
                    <button id="prevDay" class="btn btn-outline-secondary custom-day-button">&lt;</button>
                    <input type="text" id="datepicker" class="form-control datepicker-input" readonly />
                    <button id="nextDay" class="btn btn-outline-secondary custom-day-button">&gt;</button>
                </div>
            </div>
        </div>
        <div class="col-md-6 text-right">
            <div class="d-flex align-items-center justify-content-end">
                <a href="#" class="btn btn-new-appointment mr-2" onclick="redirectToNewAppointment()">
                    <i class="fas fa-plus d-md-none"></i>
                    <span class="d-none d-md-inline">Նոր Նշանակում</span>
                </a>
            </div>
        </div>
    </div>

    <div class="table-responsive d-none d-md-block">
        <table class="table table-bordered">
            <thead class="thead-light">
                <tr>
                    <th>Ժամ</th>
                    <th>Անուն</th>
                    <th>Հեռախոսահամար</th>
                    <th>Ծառայություն</th>
                    <th>Գումար</th>
                    <th>Գործողություններ</th>
                </tr>
            </thead>
            <tbody>
                @for (int hour = 6; hour < 20; hour++)
                {
                    for (int minute = 0; minute < 60; minute += 30)
                    {
                        var currentTime = new TimeSpan(hour, minute, 0);
                        var appointments = Model.Where(a => a.Appointment.AppointmentHour == currentTime).ToList();
                        var ongoingAppointment = Model.FirstOrDefault(a =>
                        a.Appointment.AppointmentHour <= currentTime &&
                        a.Appointment.AppointmentHour.Add(TimeSpan.FromMinutes(a.Appointment.Duration)) > currentTime);

                        <tr>
                            <td class="hour-cell" style="vertical-align: middle; background-color: #f2f2f2; cursor: pointer;">
                                @hour.ToString("00"):@minute.ToString("00")
                            </td>
                            @if (appointments.Any())
                            {
                                var appointment = appointments.First();
                                var rowspan = (int)Math.Ceiling(appointment.Appointment.Duration / 30.0);
                                appointmentCounter++;
                                var backgroundColor = appointmentCounter % 2 == 0 ? "#bababa" : "#d3d3d3";
                                <td style="background-color: @backgroundColor;" rowspan="@rowspan">
                                    @if (appointment.CreatedByUserId != appointment.UserId)
                                    {
                                        <span class="badge badge-info" style="margin-right: 5px;">By @appointment.CreatedByUsername</span>
                                    }
                                    @appointment.Appointment.FirstName<br />
                                </td>
                                <td style="background-color: @backgroundColor;" rowspan="@rowspan">
                                    @appointment.Appointment.PhoneNumber<br />
                                </td>
                                    <td style="background-color: @backgroundColor;" rowspan="@rowspan">
                                        <div class="service-selection-container">
                                            <input type="text" 
                                                   class="service-search form-control" 
                                                   data-id="@appointment.Appointment.Id"
                                                   data-original-name="@(appointment.Appointment.ServiceId.HasValue ? appointment.Service?.ServiceName : appointment.Appointment.CustomServiceName)"
                                                   value="@(appointment.Appointment.ServiceId.HasValue ? appointment.Service?.ServiceName : appointment.Appointment.CustomServiceName)"
                                                   placeholder="Որոնել կամ մուտքագրել"
                                                   @(appointment.Appointment.IsCompleted && !User.IsInRole("Admin") ? "readonly" : "")>
                                            <div class="service-list-container" style="display: none;">
                                                <!-- Ծառայությունների ցանկը կլցվի JavaScript-ով -->
                                            </div>
                                        </div>
                                    </td>
                                <td style="background-color: @backgroundColor;" rowspan="@rowspan">
                                    @if (!appointment.Appointment.IsCompleted || ViewBag.IsAdmin)
                                    {
                                        <span class="editable-amount" data-id="@appointment.Appointment.Id">
                                            @(appointment.Appointment.CustomPrice.HasValue ? 
                                                String.Format("{0:#,##0.00 ֏}", appointment.Appointment.CustomPrice.Value) :
                                                String.Format("{0:#,##0.00 ֏}", appointment.Service?.Price ?? 0))
                                        </span>                                        
                                    }
                                    else
                                    {
                                        <span>
                                            @(appointment.Appointment.CustomPrice.HasValue ?
                                                String.Format("{0:#,##0.00 ֏}", appointment.Appointment.CustomPrice.Value) :
                                                String.Format("{0:#,##0.00 ֏}", appointment.Service?.Price ?? 0))
                                        </span>
                                    }
                                </td>
                                <td style="background-color: @backgroundColor;" rowspan="@rowspan">
                                    <div class="btn-group" role="group" aria-label="Operations">
                                        @if (!appointment.Appointment.IsCompleted || isAdmin)
                                        {
                                            <a class="btn btn-info edit-btn" asp-action="Edit" asp-route-id="@appointment.Appointment.Id"
                                               asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
                                               style="text-decoration: none; margin-right: 5px;" onclick="event.stopPropagation()">
                                                <span>Ուղղել</span>
                                            </a>
                                            <a class="btn btn-danger delete-btn" asp-action="Delete" asp-route-id="@appointment.Appointment.Id"
                                               asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
                                               style="text-decoration: none; margin-right: 5px;" onclick="event.stopPropagation()">
                                                <span>Ջնջել</span>
                                            </a>
                                        }

                                        @if (appointment.Appointment.IsCompleted)
                                        {
                                            @if (isAdmin)
                                            {
                                                <a class="btn btn-warning" id="toggleCompletedBtn_@appointment.Appointment.Id"
                                                   style="text-decoration: none; margin-right: 5px;"
                                                   onclick="handleToggleCompletedClick(event, '@appointment.Appointment.Id', this, @Json.Serialize(isAdmin), @appointment.Appointment.IsCompleted.ToString().ToLower())"
                                                   data-price="@(appointment.Appointment.CustomPrice != null ? appointment.Appointment.CustomPrice : appointment.Service.Price)">
                                                    <span>Չեղարկել Կատարվածը</span>
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="btn btn-secondary" style="text-decoration: none; margin-right: 5px;">
                                                    <span>Կատարված</span>
                                                </span>
                                            }
                                        }
                                        else if (isAdmin || User.IsInRole("Manager"))
                                        {
                                            <a class="btn btn-success" id="toggleCompletedBtn_@appointment.Appointment.Id"
                                               style="text-decoration: none; margin-right: 5px;"
                                               onclick="handleToggleCompletedClick(event, '@appointment.Appointment.Id', this, @Json.Serialize(isAdmin), @appointment.Appointment.IsCompleted.ToString().ToLower())"
                                               data-price="@(appointment.Appointment.CustomPrice != null ? appointment.Appointment.CustomPrice : appointment.Service.Price)">
                                                <span>Նշել կատարված</span>
                                            </a>
                                        }
                                    </div>
                                </td>
                            }
                            else if (ongoingAppointment == null)
                            {
                                <td colspan="5" class="free-cell" style="background-color: #f2f2f2; cursor: pointer;" onclick="redirectToCreate('@selectedDate.ToString("yyyy-MM-dd")', '@hour.ToString("00"):@minute.ToString("00")')"></td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>


    <!-- Քարտեր մոբայլի համար -->
    <div class="appointment-cards d-md-none">
        @{
            var processedTimes = new HashSet<TimeSpan>();
        }
        @for (int hour = 6; hour < 20; hour++)
        {
            for (int minute = 0; minute < 60; minute += 30)
            {
                var currentTime = new TimeSpan(hour, minute, 0);
                var appointments = Model.Where(a => a.Appointment.AppointmentHour == currentTime).ToList();
                var ongoingAppointment = Model.FirstOrDefault(a =>
                    a.Appointment.AppointmentHour <= currentTime &&
                    a.Appointment.AppointmentHour.Add(TimeSpan.FromMinutes(a.Appointment.Duration)) > currentTime);

                if (!processedTimes.Contains(currentTime))
                {
                    @if (appointments.Any())
                    {
                        var appointment = appointments.First();
                        processedTimes.UnionWith(
                            Enumerable.Range(0, (int)Math.Ceiling(appointment.Appointment.Duration / 30.0))
                            .Select(i => currentTime.Add(TimeSpan.FromMinutes(i * 30)))
                        );

                        <div class="card mb-3 @(appointment.Appointment.IsCompleted ? "completed-appointment" : "")" data-appointment-id="@appointment.Appointment.Id">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="mb-0">@hour.ToString("00"):@minute.ToString("00")</h5>
                                    <small class="text-muted">
                                        <i class="far fa-clock"></i> 
                                        @appointment.Appointment.Duration րոպե
                                    </small>
                                </div>
                                @if (appointment.CreatedByUserId != appointment.UserId)
                                {
                                    <span class="badge badge-info">
                                        <i class="fas fa-user"></i> @appointment.CreatedByUsername
                                    </span>
                                }
                            </div>
                            <div class="card-body">
                                <div class="appointment-info">
                                    <div class="row mb-2">
                                        <div class="col-5">
                                            <i class="fas fa-user-circle"></i>
                                        </div>
                                        <div class="col-7">@appointment.Appointment.FirstName</div>
                                    </div>
                                    <div class="row mb-2">
                                        <div class="col-5">
                                            <i class="fas fa-phone"></i>
                                        </div>
                                        <div class="col-7">@appointment.Appointment.PhoneNumber</div>
                                    </div>
                                    <div class="row mb-2">
                                        <div class="col-5">
                                            <i class="fas fa-concierge-bell"></i>
                                        </div>
                                        <div class="col-7">
                                            <div class="service-selection-container">
                                                <input type="text" class="service-search form-control" 
                                                       data-id="@appointment.Appointment.Id"
                                                       value="@(appointment.Appointment.ServiceId.HasValue ? appointment.Service?.ServiceName : appointment.Appointment.CustomServiceName)"
                                                       placeholder="Որոնել կամ մուտքագրել">
                                                <div class="service-list-container" style="display: none;">
                                                    <!-- Ծառայությունների ցանկը կլցվի JavaScript-ով -->
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row mb-2">
                                        <div class="col-5">
                                            <i class="fas fa-money-bill-wave"></i>
                                        </div>
                                        <div class="col-7">
                                            <span class="editable-amount" data-id="@appointment.Appointment.Id">
                                                @(appointment.Appointment.CustomPrice.HasValue ? 
                                                    String.Format("{0:#,##0.00 ֏}", appointment.Appointment.CustomPrice.Value) :
                                                    String.Format("{0:#,##0.00 ֏}", appointment.Service?.Price ?? 0))
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <div class="button-group mt-3">
                                    @if (appointment.Appointment.IsCompleted)
                                    {
                                        @if (isAdmin)
                                        {
                                            <button class="btn btn-info btn-sm edit-btn" title="Ուղղել">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button class="btn btn-danger btn-sm delete-btn" title="Ջնջել">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                            <button class="btn btn-warning btn-sm" 
                                                    id="toggleCompletedBtn_@appointment.Appointment.Id"
                                                    onclick="handleMobileToggleCompletedClick(event, '@appointment.Appointment.Id', this, @Json.Serialize(isAdmin), @appointment.Appointment.IsCompleted.ToString().ToLower())"
                                                    data-price="@(appointment.Appointment.CustomPrice != null ? appointment.Appointment.CustomPrice : appointment.Service.Price)"
                                                    title="Չեղարկել Կատարվածը">
                                                <i class="fas fa-times-circle"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-secondary btn-sm" disabled title="Կատարված">
                                                <i class="fas fa-check-circle"></i>
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <button class="btn btn-info btn-sm edit-btn" title="Ուղղել">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-danger btn-sm delete-btn" title="Ջնջել">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                        @if (isAdmin || User.IsInRole("Manager"))
                                        {
                                            <button class="btn btn-success btn-sm"
                                                    id="toggleCompletedBtn_@appointment.Appointment.Id"
                                                    onclick="handleMobileToggleCompletedClick(event, '@appointment.Appointment.Id', this, @Json.Serialize(isAdmin), @appointment.Appointment.IsCompleted.ToString().ToLower())"
                                                    data-price="@(appointment.Appointment.CustomPrice != null ? appointment.Appointment.CustomPrice : appointment.Service.Price)"
                                                    title="Նշել կատարված">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    else if (ongoingAppointment == null)
                    {
                        <div class="card mb-3 empty-slot" onclick="redirectToCreate('@selectedDate.ToString("yyyy-MM-dd")', '@hour.ToString("00"):@minute.ToString("00")')">
                            <div class="card-body text-center">
                                <h5 class="mb-0">@hour.ToString("00"):@minute.ToString("00")</h5>
                                <small class="text-muted">
                                    <i class="fas fa-plus-circle"></i>
                                </small>
                            </div>
                        </div>
                    }
                }
            }
        }
    </div>

    <div class="container-fluid mt-4">
        <div class="row">
            <div class="col-12">
                <div class="summary-block">
                    <div class="daily-summary-toggle" onclick="toggleDailySummary()">
                        <h4 class="text-center mb-0">Օրվա ամփոփում</h4>
                    </div>
                    <div class="daily-summary-content" style="display: none;">
                        <div class="summary-container p-3">
                            <div class="row">
                                <div class="col-md-6">
                                    <h4>Ամսաթիվ: @ViewBag.SelectedDate.ToString("dd/MM/yyyy")</h4>
                                </div>
                                <div class="col-md-6 text-right">
                                    <h4>Օրվա ընդհանուր գումար (Կատարված նշանակումներ) <span id="totalCompletedAmount">@ViewBag.TotalCompletedAmount.ToString("#,##0.00 ֏")</span></h4>
                                    <h5>Կատարված նշանակումների քանակ` <span id="completedCount">@ViewBag.CompletedCount</span></h5>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="summary-block">
                <div class="income-distribution-toggle" onclick="toggleIncomeDistribution()">
                    <h4 class="text-center mb-0">Եկամտի Բաշխում</h4>
                </div>
                <div class="income-distribution-content" style="display: none;">
                    @if (ViewBag.IsAdmin || User.IsInRole("Manager"))
                    {
                        <div class="row">
                            <div class="col-md-6">
                                <h5 class="text-center">Տոկոսային հարաբերություն</h5>
                                <div class="d-flex justify-content-center mb-3">
                                    <input type="number" id="employerPercentage" class="form-control form-control-sm percentage-input mr-2" placeholder="Գործատու" value="">
                                    <input type="number" id="employeePercentage" class="form-control form-control-sm percentage-input" placeholder="Աշխատակից" value="">
                                </div>
                                <div class="text-center mt-3">
                                    <button id="saveIncomeDistribution" class="btn btn-save">Պահպանել</button>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <h5 class="text-center">Բաժանված գումարներ</h5>
                                <div class="amount-box employer mb-3">
                                    <p class="mb-1">Գործատուի մաս</p>
                                    <h4 id="employerAmount">0.00 ֏</h4>
                                </div>
                                <div class="amount-box employee">
                                    <p class="mb-1">Աշխատողի մաս</p>
                                    <h4 id="employeeAmount">0.00 ֏</h4>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row justify-content-center">
                            <div class="col-md-4">
                                <div class="amount-box employer mb-3">
                                    <h5 class="text-center">Գործատուի մաս</h5>
                                    <h4 id="employerAmount" class="text-center">0.00 ֏</h4>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="amount-box employee">
                                    <h5 class="text-center">Աշխատողի մաս</h5>
                                    <h4 id="employeeAmount" class="text-center">0.00 ֏</h4>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


@if (ViewBag.IsAdmin)
{
    <div class="text-right mt-4 mb-4">
        <a asp-action="Index" asp-controller="Home" class="btn btn-back-to-list btn-lg">Վերադառնալ Գլխավոր էջ</a>
    </div>
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://code.jquery.com/ui/1.12.1/jquery-ui.min.js"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
        const armenianLocale = {
        weekdays: {
            shorthand: ['Կիր', 'Երկ', 'Երք', 'Չոր', 'Հնգ', 'Ուրբ', 'Շբթ'],
            longhand: ['Կիրակի', 'Երկուշաբթի', 'Երեքշաբթի', 'Չորեքշաբթի', 'Հինգշաբթի', 'Ուրբաթ', 'Շաբաթ']
        },
        months: {
            shorthand: ['Հնվ', 'Փտվ', 'Մրտ', 'Ապր', 'Մյս', 'Հնս', 'Հլս', 'Օգս', 'Սպտ', 'Հկտ', 'Նմբ', 'Դկտ'],
            longhand: ['Հունվար', 'Փետրվար', 'Մարտ', 'Ապրիլ', 'Մայիս', 'Հունիս', 'Հուլիս', 'Օգոստոս', 'Սեպտեմբեր', 'Հոկտեմբեր', 'Նոյեմբեր', 'Դեկտեմբեր']
        },
        firstDayOfWeek: 1,
        ordinal: function () {
            return "";
        },
        rangeSeparator: ' — ',
        weekAbbreviation: 'Շբթ.',
        scrollTitle: 'Ոլորեք՝ մեծացնելու համար',
        toggleTitle: 'Սեղմեք՝ փոխելու համար',
        amPM: ['ԿԱ', 'ԿՀ'],
        yearAriaLabel: 'Տարի',
        monthAriaLabel: 'Ամիս',
        hourAriaLabel: 'Ժամ',
        minuteAriaLabel: 'Րոպե'
    };

    function initFlatpickr(elementId, prevButtonId, nextButtonId) {
        var fp = flatpickr(elementId, {
            dateFormat: "d/m/Y",
            defaultDate: "@selectedDate.ToString("dd/MM/yyyy")",
            onChange: function (selectedDates, dateStr, instance) {
                changeDate(dateStr);
            },
            disableMobile: true,
            enableTime: false,
            allowInput: false,
            clickOpens: true,
            locale: armenianLocale,
            theme: "custom-gray",
            nextArrow: '<svg width="16" height="16" viewBox="0 0 24 24"><path fill="currentColor" d="M8.59 16.59L13.17 12L8.59 7.41L10 6l6 6l-6 6l-1.41-1.41z"/></svg>', 
            prevArrow: '<svg width="16" height="16" viewBox="0 0 24 24"><path fill="currentColor" d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6l6 6l1.41-1.41z"/></svg>'
        });

        document.getElementById(prevButtonId).addEventListener('click', function () {
            var currentDate = fp.selectedDates[0] || new Date();
            var newDate = new Date(currentDate.setDate(currentDate.getDate() - 1));
            fp.setDate(newDate);
            changeDate(fp.formatDate(newDate, "d/m/Y"));
        });

        document.getElementById(nextButtonId).addEventListener('click', function () {
            var currentDate = fp.selectedDates[0] || new Date();
            var newDate = new Date(currentDate.setDate(currentDate.getDate() + 1));
            fp.setDate(newDate);
            changeDate(fp.formatDate(newDate, "d/m/Y"));
        });

        return fp;
    }

    var desktopFp = initFlatpickr("#datepicker", "prevDay", "nextDay");

    function changeDate(date) {
        var userId = '@ViewBag.TargetUserId';
        window.location.href = '/Appointments/Index?userId=' + userId + '&selectedDate=' + formatDateForUrl(date);
    }

    function redirectToCreate(date, time) {
        var userId = '@ViewBag.TargetUserId';
        window.location.href = '/Appointments/Create?userId=' + userId + '&date=' + date + '&time=' + time;
    }

    function redirectToNewAppointment() {
        var userId = '@ViewBag.TargetUserId';
        var currentDate = $('#datepicker').val(); // Ստանում ենք ընտրված ամսաթիվը datepicker-ից
        
        // Ձևափոխում ենք ամսաթիվը yyyy-MM-dd ֆորմատի
        var formattedDate = formatDateForUrl(currentDate);
        
        // Ուղղորդում ենք Create էջ
        window.location.href = '/Appointments/Create?userId=' + userId + '&date=' + formattedDate;
    }

    function formatDateForUrl(dateString) {
        var date = new Date(dateString);
        var year = date.getFullYear();
        var month = (date.getMonth() + 1).toString().padStart(2, '0');
        var day = date.getDate().toString().padStart(2, '0');
        return `${year}-${month}-${day}`;
    }

    function formatDateForUrl(dateString) {
        var parts = dateString.split('/');
        return parts[2] + '-' + parts[1] + '-' + parts[0];
    }

    function formatDateForServer(dateString) {
        var parts = dateString.split('/');
        return parts[2] + '-' + parts[1] + '-' + parts[0];
    }

    var totalCompletedAmount = parseFloat('@ViewBag.TotalCompletedAmount'.replace(/,/g, ''));
    var completedCount = parseInt('@ViewBag.CompletedCount');

    function updateTotalCompletedAmount() {
        $('#totalCompletedAmount').text(totalCompletedAmount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ֏');
        $('#completedCount').text(completedCount);
    }

    let calculatedEmployeeAmount = 0;
    let calculatedEmployerAmount = 0;

    function checkZeroValueAppointments() {
        var selectedDate = $('#datepicker').val();
        var formattedDate = formatDateForServer(selectedDate);
        var userId = '@ViewBag.TargetUserId';
        return $.ajax({
            url: '/Appointments/CheckZeroValueAppointments',
            type: 'GET',
            data: { date: formattedDate, userId: userId },
            dataType: 'json'
        });
    }

    function calculateSplitAmount() {
        var totalAmount = parseFloat($('#totalCompletedAmount').text().replace(/[^\d.-]/g, ''));
        var employerPercentage = parseFloat($('#employerPercentage').val()) || 0;
        var employeePercentage = parseFloat($('#employeePercentage').val()) || 0;

        if (employerPercentage + employeePercentage !== 100) {
            $('#percentageError').text('Տոկոսների գումարը պետք է լինի 100%');
            return;
        } else {
            $('#percentageError').text('');
        }

        employerPercentage = employerPercentage / 100;
        employeePercentage = employeePercentage / 100;

        calculatedEmployerAmount = totalAmount * employerPercentage;
        calculatedEmployeeAmount = totalAmount * employeePercentage;

        $('#employerAmount').text(calculatedEmployerAmount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ֏');
        $('#employeeAmount').text(calculatedEmployeeAmount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ֏');
    }

    $(document).ready(function () 
    {
        // Ֆունկցիա նշանակման տողերի ֆոնը թարմացնելու համար
        function updateAppointmentRowBackground($row, isCompleted) {
            var rowspan = parseInt($row.find('td[rowspan]').attr('rowspan'));
            var $allRows = $row.add($row.nextAll().slice(0, rowspan - 1));
            var originalColor = $row.find('td:not(.hour-cell)').first().data('original-color');

            if (isCompleted) {
                $allRows.find('td').css('background-color', 'yellow');
            } else {
                // Վերականգնել սկզբնական ֆոնի գույնը, ներառյալ ժամերի բջիջները
                $allRows.find('td').each(function () {
                    var $cell = $(this);
                    if ($cell.hasClass('hour-cell')) {
                        $cell.css('background-color', originalColor);
                    } else {
                        $cell.css('background-color', $cell.data('original-color') || '');
                    }
                });
            }
        }

        // Պահպանել սկզբնական ֆոնի գույները
        $('td').each(function () {
            var $cell = $(this);
            $cell.data('original-color', $cell.css('background-color'));
        });

        // Թարմացնել բոլոր կատարված նշանակումների ֆոնը էջի բեռնման ժամանակ
        $('tr:has(span:contains("Կատարված")), tr:has(a:contains("Չեղարկել Կատարվածը"))').each(function () {
            updateAppointmentRowBackground($(this), true);
        });

        // Փոխել handleToggleCompletedClick ֆունկցիան
        window.handleToggleCompletedClick = function (event, appointmentId, element, isAdmin, isCompleted) {
            event.stopPropagation();
            var price = parseFloat($(element).data('price'));

            $.ajax({
                url: '/Appointments/ToggleCompleted/' + appointmentId,
                type: 'POST',
                success: function (response) {
                    if (response.success) {
                        updateUI(appointmentId, response.isCompleted, isAdmin, price);
                    }
                },
                error: function (xhr, status, error) {
                    if (xhr.status === 403) {
                        alert('Դուք չունեք թույլտվություն այս գործողությունը կատարելու համար:');
                    } else {
                        alert('Սխալ տեղի ունեցավ նշանակման կարգավիճակը փոխելիս:');
                    }
                }
            });
        };

        function updateUI(appointmentId, isCompleted, isAdmin, price) {
            var $desktopRow = $('#toggleCompletedBtn_' + appointmentId).closest('tr');
            var $mobileCard = $('.card[data-appointment-id="' + appointmentId + '"]');
            var $serviceField = $desktopRow.find('.service-search');
            var $mobileServiceField = $mobileCard.find('.service-search');

            if (isCompleted) {
                updateCompletedUI($desktopRow, $mobileCard, $serviceField, $mobileServiceField, appointmentId, isAdmin);
                totalCompletedAmount += price;
                completedCount += 1;
            } else {
                updateNotCompletedUI($desktopRow, $mobileCard, $serviceField, $mobileServiceField, appointmentId, isAdmin);
                totalCompletedAmount -= price;
                completedCount -= 1;
            }

            updateTotalCompletedAmount();
        }

        function updateCompletedUI($desktopRow, $mobileCard, $serviceField, $mobileServiceField, appointmentId, isAdmin) {
            updateAppointmentRowBackground($desktopRow, true);
            var $desktopBtn = $('#toggleCompletedBtn_' + appointmentId);

            if (isAdmin) {
                updateAdminCompletedUI($desktopBtn, $mobileCard, $mobileServiceField);
            } else {
                updateNonAdminCompletedUI($desktopRow, $mobileCard, $serviceField, $mobileServiceField);
            }

            $mobileCard.addClass('completed-appointment');
        }

        function updateNotCompletedUI($desktopRow, $mobileCard, $serviceField, $mobileServiceField, appointmentId, isAdmin) {
            // Դեսքթոփի UI թարմացում
            updateAppointmentRowBackground($desktopRow, false);
            $serviceField.prop('readonly', false).css('background-color', '');
            $mobileServiceField.prop('readonly', false).css('background-color', '');

            var $desktopBtn = $('#toggleCompletedBtn_' + appointmentId);
            var $mobileBtn = $mobileCard.find('.button-group button:last-child');

            if (isAdmin) {
                $desktopBtn.removeClass('btn-warning').addClass('btn-success')
                    .html('<i class="fas fa-check d-lg-none"></i>' +
                        '<span class="d-none d-lg-inline">Նշել կատարված</span>');
                $mobileBtn.removeClass('btn-warning').addClass('btn-success')
                    .attr('title', 'Նշել կատարված')
                    .html('<i class="fas fa-check"></i>');
            }

            if (!isAdmin) {
                addEditDeleteButtons($desktopRow, $mobileCard, appointmentId);
            }

            $mobileCard.removeClass('completed-appointment');
        }

        function updateAdminCompletedUI($desktopBtn, $mobileCard, $mobileServiceField) {
            $desktopBtn.removeClass('btn-success').addClass('btn-warning')
                .html('<i class="fas fa-times-circle d-lg-none"></i>' +
                    '<span class="d-none d-lg-inline">Չեղարկել Կատարվածը</span>');

            var $mobileBtn = $mobileCard.find('.button-group button:last-child');
            $mobileBtn.removeClass('btn-success').addClass('btn-warning')
                .attr('title', 'Չեղարկել Կատարվածը')
                .html('<i class="fas fa-times-circle"></i>')
                .prop('disabled', false);  // Ապահովում ենք, որ կոճակը ակտիվ է

            // Պահպանում ենք խմբագրման և ջնջման կոճակները
            addEditDeleteButtons($mobileCard);

            // Ապահովում ենք, որ ծառայության և գումարի դաշտերը մնան խմբագրելի
            $mobileServiceField.prop('readonly', false).css('background-color', '');
            $mobileCard.find('.editable-amount').prop('readonly', false).css('background-color', '');
        }

        function updateNonAdminCompletedUI($desktopRow, $mobileCard, $serviceField, $mobileServiceField) {
            $desktopRow.find('.delete-btn, .edit-btn').remove();
            $mobileCard.find('.delete-btn, .edit-btn').remove();

            $desktopRow.find('.editable-amount').each(function () {
                var $this = $(this);
                var currentAmount = $this.text();
                $this.replaceWith('<span>' + currentAmount + '</span>');
            });

            $mobileCard.find('.editable-amount').each(function () {
                var $this = $(this);
                var currentAmount = $this.text();
                $this.replaceWith('<span>' + currentAmount + '</span>');
            });

            $serviceField.prop('readonly', true).css('background-color', '#f8f9fa');
            $mobileServiceField.prop('readonly', true).css('background-color', '#f8f9fa');

            var $desktopBtn = $desktopRow.find('.btn-success');
            var $mobileBtn = $mobileCard.find('.button-group button:last-child');

            $desktopBtn.replaceWith('<span class="btn btn-secondary" style="text-decoration: none; margin-right: 5px;">' +
                '<i class="fas fa-check-circle d-lg-none"></i>' +
                '<span class="d-none d-lg-inline">Կատարված</span></span>');

            $mobileBtn.removeClass('btn-success').addClass('btn-secondary')
                .attr('disabled', 'disabled')
                .attr('title', 'Կատարված')
                .html('<i class="fas fa-check-circle"></i>');
        }

        function addEditDeleteButtons($mobileCard, appointmentId) {
            var $buttonGroup = $mobileCard.find('.button-group');

            // Ստուգում ենք արդյոք կոճակները արդեն գոյություն ունեն
            if ($buttonGroup.find('.edit-btn').length === 0) {
                $buttonGroup.prepend(
                    '<button class="btn btn-info btn-sm edit-btn" title="Ուղղել">' +
                    '<i class="fas fa-edit"></i></button>'
                );
            }

            if ($buttonGroup.find('.delete-btn').length === 0) {
                $buttonGroup.prepend(
                    '<button class="btn btn-danger btn-sm delete-btn" title="Ջնջել">' +
                    '<i class="fas fa-trash-alt"></i></button>'
                );
            }
        }

        // Մոբայլ տարբերակի համար նոր ֆունկցիա
        window.handleMobileToggleCompletedClick = function(event, appointmentId, element, isAdmin, isCompleted) {
            // Օգտագործում ենք նույն ֆունկցիան, ինչ դեսքթոփի համար
            handleToggleCompletedClick(event, appointmentId, element, isAdmin, isCompleted);
        };

        // Էջը բեռնվելիս կաշխատի այս ֆունկցիան
        $('.appointment-cards .card').each(function() {
            var $card = $(this);
            var appointmentId = $card.data('appointment-id');
            var isCompleted = $card.hasClass('completed-appointment');
            var isAdmin = $card.find('.btn-warning').length > 0;

            if (isCompleted) {
                var $serviceField = $card.find('.service-search');
                var $amountField = $card.find('.editable-amount');
                var $toggleButton = $card.find('.btn-success, .btn-warning, .btn-secondary');
            
                if (isAdmin) {
