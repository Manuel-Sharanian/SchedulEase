@model AppointmentEditViewModel
@{
    string time = ViewBag.Time as string;
    string returnUrl = ViewBag.ReturnUrl;
}

<h2 style="color: #4a4a4a;">Ուղղել Գրանցումը</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" name="returnUrl" value="@returnUrl" />
    <div class="form-group">
        <label asp-for="FirstName" style="color: #ffffff;">Անուն</label>
        <input asp-for="FirstName" class="form-control bg-light-grey" />
    </div>
    <div class="form-group">
        <label asp-for="PhoneNumber" style="color: #ffffff;">Հեռախոսահամար</label>
        <input asp-for="PhoneNumber" class="form-control bg-light-grey" />
    </div>
    <div class="form-group">
        <label asp-for="AppointmentDate" style="color: #ffffff;">Գրանցման Օր</label>
        <input asp-for="AppointmentDate" class="form-control bg-light-grey" type="date" />
    </div>
    <div class="form-group" style="margin-bottom: 10px;">
        <label asp-for="AppointmentHour" class="control-label" style="color: #ffffff;"></label>
        <select asp-for="AppointmentHour" class="form-control bg-light-grey" asp-items="ViewBag.HourOptions">
            <option value="@time">@time</option>
            <!-- Other options can be added here if necessary -->
        </select>
        <span asp-validation-for="AppointmentHour" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="ServiceId" style="color: #ffffff;">Ծառայություն</label>
        <select asp-for="ServiceId" asp-items="Model.Services" class="form-control bg-light-grey"></select>
        <span asp-validation-for="ServiceId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="CustomPrice" style="color: #ffffff;">Հատուկ Գին</label>
        <input asp-for="CustomPrice" class="form-control bg-light-grey" type="number" step="0.01" />
    </div>
    <div class="form-group">
        <label asp-for="Duration" style="color: #ffffff;">Ժամանակ</label>
        <select asp-for="Duration" class="form-control bg-light-grey">
            <option value="30">30 րոպե</option>
            <option value="60">1 ժամ</option>
            <option value="90">1 ժամ 30 րոպե</option>
        </select>
    </div>
    <div class="text-center">
        <button type="submit" class="btn btn-primary btn-lg">Պահպանել</button>
    </div>
</form>

<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script>
    $(document).ready(function () {
        $('#ServiceId').change(function () {
            var selectedServiceId = $(this).val();
            $.ajax({
                url: '@Url.Action("GetServicePrice", "Appointments")',
                type: 'GET',
                data: { serviceId: selectedServiceId },
                success: function (price) {
                    $('#CustomPrice').val(price);
                }
            });
        });
    });
</script>

<style>
    body {
        background-color: #f2f2f2; /* Light grey background for the entire page */
        color: #ffffff; /* White text color for all text */
    }

    h2 {
        font-size: 24px; /* Larger font size for headings */
        font-weight: bold;
        text-align: center;
        margin-bottom: 20px; /* Added margin for spacing */
    }

    .form-group {
        margin-bottom: 20px; /* Added space between form groups */
    }

    .btn-primary {
        background-color: #4a4a4a; /* Dark grey button background */
        border-color: #4a4a4a;
        color: #ffffff; /* White button text */
    }

        .btn-primary:hover {
            background-color: #666666; /* Darken on hover */
            border-color: #666666;
        }

    .btn-lg {
        padding: 10px 40px; /* Larger padding for larger button */
        font-size: 18px; /* Larger font size for button text */
    }

    .form-control {
        background-color: #cccccc; /* Light grey background for form controls */
        color: #333333; /* Dark text color for form controls */
    }

        .form-control:focus {
            box-shadow: none; /* Remove focus box shadow */
        }

    .text-danger {
        color: #dc3545; /* Red color for validation messages */
    }
</style>




