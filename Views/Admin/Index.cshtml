@model List<UserViewModel>

<h2 class="text-center mb-4 page-title">Օգտատերերի կառավարում</h2> 
@* <h3 class="text-center my-4">Անհրաժեշտ է ամենաքիչը 2 Admin Account</h3> *@

 <div class="container">
    <table class="table table-striped table-hover">
        <thead class="thead-dark">
            <tr>
                <th>Օգտանուն</th>
                <th>Դերեր</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@string.Join(", ", user.Roles)</td>
                    <td>
                        <form asp-action="ChangeRole" method="post" class="d-flex mb-2">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <select name="newRole" class="form-control mr-2 custom-select">
                                <option value="Admin" selected="@(user.Roles.Contains("Admin"))">Admin</option>
                                <option value="User" selected="@(user.Roles.Contains("User"))">User</option>
                            </select>
                            <button type="submit" class="btn btn-primary">Փոխել</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <a asp-controller="IncomeReport" asp-action="Index" class="btn btn-info">Եկամտի հաշվետվություն</a>
    </table>
</div>

<style>
    .page-title {
        color: #4e4e4e;
        font-family: 'Arial', sans-serif;
        font-weight: bold;
        text-align: center;
    }

    .btn-primary {
        background-color: #4a4a4a;
    }

        .btn-primary:hover {
            background-color: #666666;
        }

    .custom-select {
        background-color: #4a4a4a;
        color: white;
        border: none;
    }

        .custom-select option {
            background-color: #4a4a4a;
            color: white;
        }

        .custom-select:focus {
            background-color: #4a4a4a;
            color: white;
            border: none;
            outline: none;
            box-shadow: none;
        }
</style> 