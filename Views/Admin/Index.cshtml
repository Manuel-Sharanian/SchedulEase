@model List<UserViewModel>

<h2 class="text-center mb-4 page-title">Օգտատերերի կառավարում</h2>

<div class="container">
    <table class="table table-striped table-hover">
        <thead class="thead-dark">
            <tr>
                <th>Օգտանուն</th>
                <th>Դերեր</th>
                <th>Գործողություններ</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>
                        <span class="badge badge-@(user.Roles.Contains("Admin") ? "danger" : "secondary")">
                            @string.Join(", ", user.Roles)
                        </span>
                    </td>
                    <td>
                        <form asp-action="ChangeRole" method="post" class="d-flex mb-2">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <select name="newRole" class="form-control mr-2 custom-select">
                                <option value="Admin" selected="@(user.Roles.Contains("Admin"))">Admin</option>
                                <option value="User" selected="@(user.Roles.Contains("User"))">User</option>
                            </select>
                            <button type="submit" class="btn btn-primary mr-2">Փոխել</button>
                        </form>
                        @if (!user.Roles.Contains("Admin"))
                        {
                            <form asp-action="DeleteUser" method="post" onsubmit="return confirm('Վստա՞հ եք, որ ցանկանում եք ջնջել այս օգտատիրոջը:');">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <button type="submit" class="btn btn-danger">Ջնջել</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <a asp-controller="IncomeReport" asp-action="Index" class="btn btn-info">Եկամտի հաշվետվություն</a>
</div>

<style>
    .page-title {
        color: #4e4e4e;
        font-family: 'Arial', sans-serif;
        font-weight: bold;
        text-align: center;
    }

    .btn-primary {
        background-color: #4a4a4a;
    }

        .btn-primary:hover {
            background-color: #666666;
        }

    .custom-select {
        background-color: #4a4a4a;
        color: white;
        border: none;
    }

        .custom-select option {
            background-color: #4a4a4a;
            color: white;
        }

        .custom-select:focus {
            background-color: #4a4a4a;
            color: white;
            border: none;
            outline: none;
            box-shadow: none;
        }

    .btn-danger {
        background-color: #dc3545;
    }

        .btn-danger:hover {
            background-color: #c82333;
        }

    /* Badge Styles for Role Visibility */
    .badge-danger {
        background-color: #dc3545;
        color: white;
        font-weight: bold;
        padding: 5px 10px;
        border-radius: 12px;
    }

    .badge-secondary {
        background-color: #6c757d;
        color: white;
        font-weight: bold;
        padding: 5px 10px;
        border-radius: 12px;
    }

    /* Row Hover Highlight */
    tr:hover {
        background-color: #6c757d;
    }
</style>
