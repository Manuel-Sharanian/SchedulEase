@model IEnumerable<BeautySalon.Models.Client>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Այցելուներ";
}

<h1 class="text-center mb-4 page-title">Այցելուների Ցանկ</h1>

@if (User.IsInRole("Admin"))
{
    <p>
        <a class="btn btn-success" asp-action="Create" style="text-decoration: none;">Ավելացնել Նոր Այցելու</a>
    </p>
}

<form class="form-inline my-2 my-lg-0">
    <div class="input-group">
        <input type="text" id="searchString" class="form-control" placeholder="Որոնել անձը" aria-label="Search" onkeyup="searchClients()" style="width: 300px;">
    </div>
</form>

<div id="searchResults">
    @await Html.PartialAsync("_ClientList", Model)
</div>

<style>
    body {
        background-color: #e0e0e0;
    }

    .page-title {
        color: #4e4e4e;
        font-family: 'Arial', sans-serif;
        font-weight: bold;
        text-align: center;
    }

    .btn-success {
        background-color: #4a4a4a;
        border-color: #4a4a4a;
    }

        .btn-success:hover {
            background-color: #666666;
            border-color: #666666;
        }

    .form-inline .input-group .form-control {
        padding: 10px;
        margin-bottom: 5px;
        box-shadow: 0 0 5px rgba(0, 0, 0, 0.1);
        transition: box-shadow 0.3s ease, border-color 0.3s ease;
        background-color: #4a4a4a;
        color: white;
        border: none;
    }

        .form-inline .input-group .form-control::placeholder {
            color: #f0f0f0;
        }

        .form-inline .input-group .form-control:focus {
            box-shadow: 0 0 10px rgba(128, 128, 128, 0.5);
            border-color: #808080;
            background-color: #4a4a4a;
            color: white;
        }

    .table {
        margin-top: 20px;
        border: 1px solid #ddd;
        background-color: #f9f9f9;
    }

        .table th, .table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        .table th {
            background-color: #4a4a4a;
            color: white;
        }

        .table tbody tr:hover {
            background-color: #f1f1f1;
        }
</style>

@* AJAX Command to search client dynamically *@
@section Scripts {
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script type="text/javascript">
        function searchClients() {
            var searchString = $('#searchString').val();
            $.ajax({
                url: '@Url.Action("Search", "Clients")',
                data: { searchString: searchString },
                success: function (data) {
                    $('#searchResults').html(data);
                }
            });
        }
    </script>
}