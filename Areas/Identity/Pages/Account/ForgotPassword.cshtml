@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Մոռացե՞լ եք գաղտնաբառը";
}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="forgot-password-form">
                <h2 class="text-center mb-4">@ViewData["Title"]</h2>
                <p class="text-center mb-4">Մուտքագրեք ձեր Էլ-փոստը․</p>
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control transparent-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="form-label">Էլ-փոստ</label>
                        <span asp-validation-for="Input.Email" class="text-danger">Պարտադիր է լրացնել․</span>
                    </div>
                    <button type="submit" class="w-100 btn btn-lg btn-primary">Փոխել գաղտնաբառը</button>
                </form>
                <div class="mt-3 text-center">
                    <p>
                        <a class="custom-link" asp-page="./Login">Վերադառնալ մուտքի էջ</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    body {
        background-color: #f8f9fa;
    }
    .forgot-password-form {
        background-color: #e0e0e0; /* Բաց մոխրագույն ետնագույն */
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        margin-top: 50px;
    }
    .transparent-input {
        background-color: rgba(255, 255, 255, 0.8);
    }
    .btn-primary {
        background-color: #4a4a4a;
        border-color: #4a4a4a;
    }
    .btn-primary:hover {
        background-color: #666666;
        border-color: #666666;
    }
    .custom-link {
        color: #4a4a4a;
        text-decoration: none;
        transition: color 0.3s ease;
        font-weight: bold;
    }
    .custom-link:hover {
        color: #007bff;
        text-decoration: underline;
    }
</style>