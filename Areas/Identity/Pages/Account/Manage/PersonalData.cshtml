@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3>@ViewData["Title"]</h3>

<div class="row justify-content-center my-4">
    <div class="col-md-8 manage-data-container">
        <h4 class="text-center mb-3">Manage Your Personal Data</h4>
        <p>
            <strong>Deleting this data will permanently remove your account, and this cannot be recovered.</strong>
        </p>
@*         <form id="download-data" asp-page="DownloadPersonalData" method="post">
            <button class="btn btn-light btn-block mt-2" type="submit">Download</button>
        </form> *@
        <p class="text-center mt-3">
            <a id="delete" asp-page="DeletePersonalData" class="btn btn-danger btn-block">Delete</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    /* Custom styling for the manage personal data section */
    .manage-data-container {
        background-color: #6c757d; /* Bootstrap secondary color */
        color: #ffffff; /* White text color */
        padding: 20px;
        border-radius: 5px;
        border: 1px solid #5a6268; /* Slightly darker border */
    }

        .manage-data-container h4 {
            color: #e2e3e5; /* Lighter grey for the heading */
        }

        .manage-data-container .btn-light {
            color: #6c757d; /* Match button text color to the background */
        }

        .manage-data-container .btn-danger {
            color: #ffffff; /* White text for delete button */
        }
</style>
