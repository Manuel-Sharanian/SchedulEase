@page
@model LoginModel
@{
    ViewData["Title"] = "Մուտք";
}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="login-form">
                <h2 class="text-center mb-4">@ViewData["Title"]</h2>
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control transparent-input" autocomplete="on" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="form-label">Էլ․ փոստ</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control transparent-input" autocomplete="off" aria-required="true" placeholder="password" />
                        <label asp-for="Input.Password" class="form-label">Գաղտնաբառ</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    @*                     <div class="checkbox mb-3">
                    <label asp-for="Input.RememberMe" class="form-label">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    Հիշել ինձ
                    </label>
                    </div> *@
                    <div>
                        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Մուտք գործել</button>
                    </div>
                    <div class="mt-3 text-center">
                        <p>
                            <a id="forgot-password" class="custom-link" asp-page="./ForgotPassword">Մոռացե՞լ եք գաղտնաբառը</a>
                        </p>
                        <p>
                            <a class="custom-link" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Գրանցվել որպես նոր օգտատեր</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
<style>
    body {
        background-color: #f8f9fa;
    }
    .login-form {
        background-color: #e0e0e0; /* Բաց մոխրագույն ետնագույն */
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        margin-top: 50px;
    }
    .transparent-input {
        background-color: rgba(255, 255, 255, 0.8);
    }
    .btn-primary {
        background-color: #4a4a4a;
        border-color: #4a4a4a;
    }
    .btn-primary:hover {
        background-color: #666666;
        border-color: #666666;
    }
    .custom-link {
        color: #4a4a4a;
        text-decoration: none;
        transition: color 0.3s ease;
        font-weight: bold;
    }
    .custom-link:hover {
        color: #007bff;
        text-decoration: underline;
    }
</style>